{
  "meta": {
    "name": "Ribkoff v2 operator specs (hand-authored for benchmark)",
    "source": "data/GI/V2_Joseph_Ribkoff_Inspection_Rules_Reference.md"
  },
  "specs": {
    "3_1_6": {
      "checkpoint_id": "3_1_6",
      "tier": "deterministic",
      "operator": "no_photos_when_pass",
      "params": {
        "result_field": "node.carton_drop_test.result",
        "photos_field": "node.carton_drop_test.photos.count"
      },
      "extract": [
        {
          "field": "node.carton_drop_test.result",
          "question": "What is the Carton drop test result? (PASS, FAIL, or NOT_APPLICABLE)",
          "type": "string"
        },
        {
          "field": "node.carton_drop_test.photos.count",
          "question": "How many photos are attached to the Carton drop test checkpoint?",
          "type": "integer"
        }
      ]
    },
    "3_1_7": {
      "checkpoint_id": "3_1_7",
      "tier": "deterministic",
      "operator": "no_photos_allowed",
      "params": {
        "photos_field": "node.outer_packing_assortment_dimensions_weight.photos.count"
      },
      "extract": [
        {
          "field": "node.outer_packing_assortment_dimensions_weight.photos.count",
          "question": "How many photos are on Outer Packing: Assortment, Dimensions & Weight?",
          "type": "integer"
        }
      ]
    },
    "3_2_3": {
      "checkpoint_id": "3_2_3",
      "tier": "deterministic",
      "operator": "must_not_be_na",
      "params": {
        "result_field": "node.product_logo.result",
        "values_field": "node.product_logo.values"
      },
      "extract": [
        {
          "field": "node.product_logo.result",
          "question": "What is the Product Logo checkpoint result?",
          "type": "string"
        },
        {
          "field": "node.product_logo.values",
          "question": "What value(s) are recorded for Product Logo? Return as comma-separated text.",
          "type": "string"
        }
      ]
    },
    "5_2_1": {
      "checkpoint_id": "5_2_1",
      "tier": "deterministic",
      "operator": "photo_count_at_most",
      "params": {
        "photos_field": "node.color_shading_check.photos.count",
        "max": 1
      },
      "extract": [
        {
          "field": "node.color_shading_check.photos.count",
          "question": "How many photos are on the Color shading check?",
          "type": "integer"
        }
      ]
    },
    "5_2_2": {
      "checkpoint_id": "5_2_2",
      "tier": "deterministic",
      "operator": "comment_has_number",
      "params": {
        "comment_field": "node.stitch_density_check.comment"
      },
      "extract": [
        {
          "field": "node.stitch_density_check.comment",
          "question": "What is the inspector comment on the Stitch density check?",
          "type": "string"
        }
      ]
    },
    "5_1_1": {
      "checkpoint_id": "5_1_1",
      "tier": "deterministic",
      "operator": "filename_matches",
      "params": {
        "filenames_field": "node.product_dimensions_result.attachments.filenames",
        "pattern": "Measurement Chart-{style}.xlsx"
      },
      "extract": [
        {
          "field": "node.product_dimensions_result.attachments.filenames",
          "question": "What is the measurement chart attachment filename on Product Dimensions Result?",
          "type": "string",
          "context_field": "node.product_dimensions_result.attachments.filenames"
        }
      ]
    },
    "1_2_1": {
      "checkpoint_id": "1_2_1",
      "tier": "extract",
      "operator": "all_true",
      "params": {
        "fields": [
          "extract.1_2_1.has_po_breakdown",
          "extract.1_2_1.has_percentage"
        ]
      },
      "extract": [
        {
          "field": "extract.1_2_1.has_po_breakdown",
          "question": "Does the inspector remark list defects broken down by PO number?",
          "type": "boolean",
          "context_field": "summary.global_remark"
        },
        {
          "field": "extract.1_2_1.has_percentage",
          "question": "Does the inspector remark include a total defect percentage?",
          "type": "boolean",
          "context_field": "summary.global_remark"
        }
      ]
    },
    "7_1_1": {
      "checkpoint_id": "7_1_1",
      "tier": "deterministic",
      "operator": "equals",
      "params": {
        "field": "summary.aql.aql_level_major",
        "expected": 2.5
      },
      "extract": [
        {
          "field": "summary.aql.aql_level_major",
          "question": "What is the major AQL level shown in the workmanship section?",
          "type": "number"
        }
      ]
    },
    "7_1_2": {
      "checkpoint_id": "7_1_2",
      "tier": "deterministic",
      "operator": "equals",
      "params": {
        "field": "summary.aql.aql_level_minor",
        "expected": 4.0
      },
      "extract": [
        {
          "field": "summary.aql.aql_level_minor",
          "question": "What is the minor AQL level shown in the workmanship section?",
          "type": "number"
        }
      ]
    },
    "1_3_1": {
      "checkpoint_id": "1_3_1",
      "tier": "deterministic",
      "operator": "ratio_at_least",
      "params": {
        "numerator": "summary.quantities._first_product.packed_actual",
        "denominator": "summary.quantities._first_product.ordered",
        "min": 0.8
      }
    },
    "8_1_1": {
      "checkpoint_id": "8_1_1",
      "tier": "deterministic",
      "operator": "overall_pass_requires_ratio",
      "params": {
        "result_field": "summary.inspection_result",
        "ratio": {
          "numerator": "summary.quantities._first_product.packed_actual",
          "denominator": "summary.quantities._first_product.ordered",
          "min": 0.8
        }
      }
    }
  }
}
