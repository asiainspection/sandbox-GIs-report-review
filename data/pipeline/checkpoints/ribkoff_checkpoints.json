      "source_lines": {},
      "context": "QUESTION",
      "check_block": {
        "where": [
          {
            "kind": "checklist",
            "match": [
              "defects"
            ],
            "field": "photo_content"
          }
        ],
        "when": {
          "op": "_macro_ref",
          "check": "defects_name_any(\"untrimmed\", \"thread\")",
          "where": [
            "report.defects"
          ]
        },
        "check": "vision(\"For untrimmed-thread defects, is any thread longer than about 1/4 inch classified as MINOR?\")",
        "row_type": "Rule"
      }
    },
